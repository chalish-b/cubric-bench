{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cubric-bench",
  "compatibility_date": "2026-06-19",
  // Static-assets-only Worker (no server script). single-page-application
  // serves index.html for non-asset paths so client-side routes like
  // /entry/<id> work on refresh / deep link. Real files such as /data/*.json
  // are served directly as assets.
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
